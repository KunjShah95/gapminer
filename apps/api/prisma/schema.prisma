// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String     @id @default(uuid())
  email          String     @unique
  name           String?
  avatar         String?
  plan           String     @default("free")
  analysesUsed   Int        @default(0)
  analysesLimit  Int        @default(10)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  
  analyses       Analysis[]
  candidates     Candidate[]
  negotiationSessions NegotiationSession[]
}

model Analysis {
  id                    String   @id @default(uuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  resumeText            String
  jobDescriptionText    String
  
  // Structured outputs from our AI agents
  resumeData            Json?
  jdData                Json?
  gapAnalysis           Json?
  roadmap               Json?
  courseRecommendations Json?
  interviewPrep         Json?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Skill {
  id            String   @id @default(uuid())
  name          String   @unique
  canonicalName String?
  description   String?
  synonyms      String[] // Array of aliases: ["JS", "ReactJS"]
  
  categoryId    String?
  category      SkillCategory? @relation(fields: [categoryId], references: [id])
  
  parentSkillId String?
  parentSkill   Skill?  @relation("SkillHierarchy", fields: [parentSkillId], references: [id])
  subSkills     Skill[] @relation("SkillHierarchy")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SkillCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  skills    Skill[]
  createdAt DateTime @default(now())
}

model Candidate {
  id           String   @id @default(uuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  name         String
  email        String?
  resumeText   String
  parsedData   Json?    // Structured extraction
  skillsFound  String[] // Canonical skill IDs
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SalaryBenchmark {
  id              String   @id @default(uuid())
  companyTier     String   @default("mid") // faang, faang+, mid, startup
  roleTitle       String
  location        String   // City, Country
  countryCode     String?  // ISO country code
  minSalary       Int
  medianSalary    Int
  maxSalary       Int
  totalCompMin    Int      // Includes bonus/stock
  totalCompMedian Int
  totalCompMax    Int
  yearsExperience Int      // 0-1, 1-3, 3-5, 5-10, 10+
  dataSource      String   @default("aggregated")
  sampleSize      Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([roleTitle, location, companyTier, yearsExperience])
  @@index([roleTitle, location])
}

model NegotiationSession {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  targetRole        String
  targetCompany    String?
  location         String?
  currentOffer     Json?     // { base: number, bonus: number, stock: number, signing: number }
  competingOffers  Json?     // Array of competing offers
  
  salaryBenchmark  Json?     // Retrieved benchmark data
  negotiationPlan  Json?     // Generated negotiation strategy
  outcome          String?   // accepted, declined, pending
  finalComp        Json?     // Final accepted comp
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model CompanyIntelligence {
  id                String   @id @default(uuid())
  name              String   @unique
  tier              String   @default("mid") // faang, faang+, mid, startup
  negotiationStyle  String?  // aggressive, data-driven, formula-based, negotiable
  typicalBenefits   String[]
  equityCulture    String?   // high-equity, cash-heavy, balanced
  hiringVelocity   String?   // fast, moderate, slow
  counterOfferRate Float?    // Percentage of candidates who negotiate
  
  salaryMultiplier Json?     // { L4: 1.0, L5: 1.1, etc } relative to market
  notes            String?
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

