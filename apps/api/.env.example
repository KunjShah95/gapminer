# =============================================================================
# IMPORTANT SECURITY NOTES FOR PRODUCTION
# =============================================================================
# 1. SECRET_KEY must be at least 32 characters and randomly generated
# 2. Set NODE_ENV=production when deploying
# 3. Never commit this file - add to .gitignore
# 4. Rotate all API keys periodically
# =============================================================================

# Environment - MUST be "production" in production
NODE_ENV=development

# Database - REQUIRED in production
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gapminer

# Auth - CRITICAL: Generate a secure random key (e.g., openssl rand -hex 32)
SECRET_KEY=change-this-to-a-secure-random-key-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Redis
REDIS_URL=redis://localhost:6379/0

# S3 / Cloudflare R2 (for resume storage)
S3_BUCKET=gapminer-resumes
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Ollama (Local AI)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# AI Provider API Keys (at least one required for cloud AI)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
OPENROUTER_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
DEEPSEEK_API_KEY=

# Default AI Model
DEFAULT_MODEL=anthropic/claude-3.5-sonnet
DEFAULT_PROVIDER=openrouter

# CORS - specify exact origins in production
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Sentry (Optional - for error tracking)
SENTRY_DSN=

# App Settings
DEBUG=false
APP_NAME=GapMiner API
PORT=8000

# SMTP (Email) - configure for password resets
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@gapminer.com

# Stripe (Payments)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_TEAMS_MONTHLY=
FRONTEND_URL=http://localhost:3000
