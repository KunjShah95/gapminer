# =============================================================================
# GapMiner Production Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment
# WARNING: Never commit .env files to version control!
# =============================================================================

# ========================================
# REQUIRED - Application
# ========================================

# Domain for CORS and redirects (e.g., yourdomain.com)
DOMAIN=your-domain.com

# Secret key for JWT signing - Generate a strong random key!
# Use: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this

# ========================================
# REQUIRED - Database
# ========================================

DB_USER=postgres
DB_PASSWORD=your-strong-postgres-password

# ========================================
# REQUIRED - Redis
# ========================================

# Redis password (optional - remove if not using auth)
REDIS_PASSWORD=

# ========================================
# OPTIONAL - Monitoring
# ========================================

# Sentry DSN for error tracking (get from sentry.io)
SENTRY_DSN=

# ========================================
# OPTIONAL - AI Providers
# ========================================

# Ollama (local AI) - only if running locally
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# At least one cloud AI provider (if not using Ollama)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
OPENROUTER_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
DEEPSEEK_API_KEY=

# Default model (used when none specified)
DEFAULT_MODEL=anthropic/claude-3.5-sonnet
DEFAULT_PROVIDER=openrouter

# Firecrawl for job description scraping
FIRECRAWL_API_KEY=

# Google Generative AI
GOOGLE_GENERATIVE_AI_KEY=

# ========================================
# OPTIONAL - Storage (AWS S3 / Cloudflare R2)
# ========================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=gapminer-resumes
AWS_REGION=us-east-1

# ========================================
# OPTIONAL - Payments (Stripe)
# ========================================

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ========================================
# OPTIONAL - Email (SMTP)
# ========================================

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@your-domain.com

# ========================================
# OPTIONAL - Auth (Google OAuth)
# ========================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ========================================
# DEVELOPMENT ONLY - Do not use in production
# ========================================

# DEBUG=false  # Set to true only for troubleshooting