# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gapminer

# Auth
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redis
REDIS_URL=redis://localhost:6379/0

# S3 / Cloudflare R2
S3_BUCKET=gapminer-resumes
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Ollama (Local AI)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Sentry (Optional)
SENTRY_DSN=

# App
DEBUG=true
APP_NAME=GapMiner API